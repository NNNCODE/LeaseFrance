# Optional hosted integrations.
# These variables are read at build/package time by the scripts in `scripts/`.
# Export them in your shell or CI environment before running `npm run build`
# or `npm run dist` if you want to enable these features.

# Optional packaged license activation endpoint.
# Example:
# BAILLIO_LICENSE_API_URL=https://licenses.example.com
BAILLIO_LICENSE_API_URL=

# Optional packaged auto-update feed.
# Example:
# BAILLIO_UPDATE_URL=https://updates.example.com/baillio/
BAILLIO_UPDATE_URL=

# Optional update channel. Defaults to `latest` when update URL is set.
BAILLIO_UPDATE_CHANNEL=

# Optional development flag for testing auto-update locally.
# Use `1` only when you explicitly want dev-mode update checks.
BAILLIO_ENABLE_DEV_UPDATES=
